    <!-- ================================= DYNAMIC RESOURCES - /index.html ======================= -->
    <!-- NO SEO and I18N support -->
    <rule>
        <from>^/$</from>
        <to last="true">/index.html</to>
    </rule>
    <outbound-rule>
        <from>^/index.html$</from>
        <to>/</to>
    </outbound-rule>
    <!-- ================================= DYNAMIC RESOURCES - /Product/* ======================= -->
    <!-- NO SEO or I18N support -->
