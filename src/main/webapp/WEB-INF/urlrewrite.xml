<?xml version="1.0" encoding="utf-8"?>
<!DOCTYPE urlrewrite PUBLIC "-//tuckey.org//DTD UrlRewrite 4.0//EN"
        "http://www.tuckey.org/res/dtds/urlrewrite4.0.dtd">
<urlrewrite>

    <!-- Remove jsessionid to avoid problem with urls containing  sessionid in cached pages,
and avoid 404 error on jetty when accessing I18N urls like /trang-chu.html;jsessionid=aaa -->
    <outbound-rule encodefirst="true">
        <from>^(.*?)(?:\;jsessionid=[^\?#]*)?(\?[^#]*)?(#.*)?$</from>
        <to>$1$2$3</to>
    </outbound-rule>

    <!-- ================================= DYNAMIC RESOURCES - /admin/* ======================= -->
    <!-- NO SEO or I18N support -->
    <rule>
        <from>^/admin$</from>
        <to last="true">/admin/index.html</to>
    </rule>
    <rule>
        <from>^/admin/$</from>
        <to last="true">/admin/index.html</to>
    </rule>

    <!-- ================================= DYNAMIC RESOURCES - /checkout/* ======================= -->
    <!-- NO SEO or I18N support -->
    <rule>
        <from>^/checkout$</from>
        <to last="true">/checkout/basket.html</to>
    </rule>
    <rule>
        <from>^/checkout/$</from>
        <to last="true">/checkout/basket.html</to>
    </rule>

    <!-- ================================= DYNAMIC RESOURCES - /news/* ======================= -->
    <!-- NO SEO or I18N support -->
    <rule>
        <from>^/news/(.*)$</from>
        <to>/news/$1</to>
    </rule>
    <rule>
        <from>^/tin-tuc/(.*)$</from>
        <to>/news/$1</to>
    </rule>
    <outbound-rule>
        <from>^/news/(.*)$</from>
        <run class="com.easysoft.ecommerce.web.filter.URITransalator" method="outBoundNews"/>
        <to>/%{attribute:target}/$1</to>
    </outbound-rule>
    <!-- ================================= DYNAMIC RESOURCES - /contact us* ======================= -->
    <!-- NO SEO or I18N support -->
    <rule>
        <from>^/contact-us.html$</from>
        <to>/contact-us.html</to>
